<?xml version="1.0"?>
<robot name="2AxisArm">

  <!-- Materials -->
  <material name="base_gray">
    <color rgba="0.55 0.60 0.70 1"/>
  </material>

  <material name="copper">
    <color rgba="0.90 0.55 0.32 1"/>
  </material>

  <material name="arm_gray">
    <color rgba="0.45 0.45 0.45 1"/>
  </material>


  <!-- ===================== -->
  <!-- Links -->
  <!-- ===================== -->

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="STLs/ActualBase.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="base_gray"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="STLs/ActualBase.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>


  <link name="yaw_link">
    <visual>
      <geometry>
        <mesh filename="STLs/Yaw.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="copper"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="STLs/Yaw.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>


  <link name="lower_arm_link">
    <visual>
      <geometry>
        <mesh filename="STLs/LowerArm.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="STLs/LowerArm.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.7"/>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>


  <link name="upper_arm_link">
    <visual>
      <geometry>
        <mesh filename="STLs/UpperArm.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="STLs/UpperArm.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.135 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>


  <!-- Empty target point at the end of the upper arm -->
  <link name="tool0"/>


  <!-- ===================== -->
  <!-- Joints -->
  <!-- ===================== -->

  <!-- Base yaw: true base -> copper rotating base -->
  <joint name="joint0_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1"/>
  </joint>


  <!-- Shoulder pitch: copper base -> lower arm -->
  <joint name="joint1_shoulder" type="revolute">
    <parent link="yaw_link"/>
    <child link="lower_arm_link"/>
    <origin xyz="0 0 0.100" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>


  <!-- Elbow pitch: lower arm -> upper arm -->
  <joint name="joint2_elbow" type="revolute">
    <parent link="lower_arm_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0.250 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="10" velocity="1"/>
  </joint>


  <!-- Temporary tool/end point: upper arm -> endpoint -->
  <joint name="fixed_tool0" type="fixed">
    <parent link="upper_arm_link"/>
    <child link="tool0"/>
    <origin xyz="0.270 0 0" rpy="0 0 0"/>
  </joint>

</robot>